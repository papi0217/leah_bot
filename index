    <style>
:root {
    /* Hyper-realistic polished gold */
    --gold-1: #FFF5C8;
    --gold-2: #F5D97A;
    --gold-3: #D4A72C;
    --gold-4: #B8860B;
    --gold-5: #7A5500;
    --gold-metal: linear-gradient(135deg, #FFF5C8 0%, #F5D97A 12%, #D4A72C 28%, #B8860B 42%, #E8C050 55%, #F5D97A 65%, #D4A72C 78%, #9A6A00 92%, #C9A030 100%);
    --gold-metal-flat: linear-gradient(135deg, #F5D97A 0%, #D4A72C 35%, #F0C040 55%, #B8860B 80%, #E0B030 100%);
    --gold-shine: linear-gradient(105deg, transparent 20%, rgba(255,245,180,0.9) 35%, rgba(255,250,220,1) 50%, rgba(255,245,180,0.9) 65%, transparent 80%);
    /* Pearl whites */
    --pearl-pure: #FDFCF8;
    --pearl-warm: #F5F0E8;
    --pearl-mid: #EDE6D8;
    --pearl-deep: #E0D5C0;
    --pearl-shadow: rgba(160,140,100,0.12);
    /* Obsidian */
    --obsidian: #08080A;
    --obsidian-2: #0E0E12;
    --obsidian-3: #141418;
    --obsidian-4: #1C1C22;
    /* Type on pearl */
    --ink: #1A1610;
    --ink-mid: #3D3525;
    --ink-light: #6B5D45;
    --ink-faint: #9A8E7A;
    /* Type on dark */
    --pearl: #F0EDE8;
    --pearl-dim: #C8C4BC;
    --steel: #8A8A9A;
    --steel-light: #B4B4C4;
    --white: #FAFAF8;
    /* Borders */
    --border-gold: rgba(212,167,44,0.25);
    --border-dark: rgba(255,255,255,0.06);
    --border-pearl: rgba(160,140,100,0.2);
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body {
    background: var(--obsidian);
    font-family: 'Jost', sans-serif;
    color: var(--pearl);
    line-height: 1.6;
    overflow-x: hidden;
    position: relative;
}

/* BOT IMAGE BACKGROUND WALLPAPER - REPLACE WITH YOUR IMAGE */
body::after {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('YOUR-BOT-IMAGE-HERE.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
    mix-blend-mode: soft-light;
}

/* Grain texture overlay */
body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    opacity: 0.022;
    pointer-events: none;
    z-index: 9998;
}

/* All content sits above background */
section, footer, .nav, .cookie-consent, .legal-overlay {
    position: relative;
    z-index: 1;
}

/* Language Toggle Button */
.lang-toggle {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(212,167,44,0.3);
    color: var(--gold-2);
    padding: 0.5rem 1.2rem;
    cursor: pointer;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: all 0.3s;
    font-family: 'Jost', sans-serif;
}
.lang-toggle:hover {
    background: rgba(212,167,44,0.15);
    border-color: var(--gold-2);
}

/* Scrolling Chat Reels Section */
.chat-reels {
    padding: 6rem 5%;
    background: linear-gradient(180deg, var(--obsidian-2) 0%, var(--obsidian) 100%);
    position: relative;
    overflow: hidden;
}
.chat-reels::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-gold), transparent);
}
.chat-reels-container {
    max-width: 1200px;
    margin: 0 auto;
}
.chat-reels-header {
    text-align: center;
    margin-bottom: 3rem;
}
.chat-reels-header .section-label {
    color: var(--gold-2);
}
.chat-reels-header h2 {
    color: var(--white);
    font-size: 2.8rem;
}
.chat-reels-carousel {
    position: relative;
    min-height: 380px;
    background: rgba(0,0,0,0.3);
    border-radius: 24px;
    border: 1px solid rgba(212,167,44,0.15);
    overflow: hidden;
    box-shadow: 0 20px 40px -15px rgba(0,0,0,0.4), inset 0 1px 0 rgba(255,255,255,0.03);
}
.chat-reel {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity 0.8s cubic-bezier(0.23, 1, 0.32, 1);
    pointer-events: none;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
}
.chat-reel.active {
    opacity: 1;
    pointer-events: auto;
}
.reel-messages {
    max-width: 700px;
    margin: 0 auto;
    width: 100%;
}
.reel-message {
    margin-bottom: 1.2rem;
    animation: messageSlideIn 0.5s ease forwards;
}
@keyframes messageSlideIn {
    from {
        opacity: 0;
        transform: translateY(15px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
.reel-message.guest {
    display: flex;
    justify-content: flex-end;
}
.reel-message.leah {
    display: flex;
    justify-content: flex-start;
}
.reel-bubble {
    max-width: 80%;
    padding: 0.9rem 1.2rem;
    border-radius: 20px;
    font-size: 0.9rem;
    line-height: 1.5;
}
.reel-bubble.guest {
    background: linear-gradient(135deg, #2A2218, #1A1610);
    color: var(--pearl);
    border-radius: 20px 20px 4px 20px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.2);
}
.reel-bubble.leah {
    background: linear-gradient(135deg, #FFFFFF, #F8F3EA);
    color: var(--ink);
    border: 1px solid rgba(184,134,11,0.15);
    border-radius: 20px 20px 20px 4px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.05);
}
.reel-name {
    font-size: 0.7rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
    letter-spacing: 0.5px;
}
.reel-name.guest { color: var(--gold-2); }
.reel-name.leah { color: var(--gold-4); }
.reel-time {
    font-size: 0.55rem;
    color: var(--ink-faint);
    margin-top: 0.3rem;
    text-align: right;
}
.reel-bubble.guest .reel-time { color: rgba(240,237,232,0.5); }
.reel-category {
    display: inline-block;
    font-size: 0.55rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--gold-3);
    margin-top: 0.5rem;
}
.reel-indicators {
    display: flex;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 1.5rem;
}
.reel-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    cursor: pointer;
    transition: all 0.3s;
}
.reel-dot.active {
    background: var(--gold-3);
    width: 24px;
    border-radius: 4px;
}

/* Rest of existing styles preserved */
.cursor {
    width: 5px; height: 5px;
    background: var(--gold-2);
    border-radius: 50%;
    position: fixed; pointer-events: none;
    z-index: 10001;
    transition: width 0.2s, height 0.2s;
    mix-blend-mode: screen;
}
.cursor-follower {
    width: 38px; height: 38px;
    border: 1px solid rgba(212,167,44,0.5);
