<script>
// ============================================================================
// SCROLLING CHAT REELS - 8 DIFFERENT CONVERSATIONS WITH DIFFERENT GUESTS
// ============================================================================
const chatReels = [
    { guest: "Juan", guestMsg: "what's the wifi?", leahMsg: "The WiFi network is VillaLumina_Guest and the password is MiamiSun2024. The router is in the living room cabinet. Is there anything else I can assist you with?", category: "WiFi & Access", time: "10:32 PM" },
    { guest: "Maria", guestMsg: "what time is check-in?", leahMsg: "Check-in is at 4:00 PM. Your access code is 7742#. Would you like me to also share the WiFi details or go over the house rules?", category: "Check-in", time: "2:15 PM" },
    { guest: "Alexander", guestMsg: "the toilet is not flushing", leahMsg: "I sincerely apologise for the inconvenience. I am alerting the property manager at this very moment. You may expect contact within thirty minutes. Your comfort is our utmost priority.", category: "Maintenance Escalation", time: "11:47 PM" },
    { guest: "Elena", guestMsg: "fire alarm", leahMsg: "If this is a life-threatening emergency, please contact 911 immediately. I am simultaneously alerting the property manager. Please remain calm — assistance is forthcoming within 15 minutes.", category: "Emergency Escalation", time: "3:22 AM" },
    { guest: "William", guestMsg: "recommend a restaurant for dinner", leahMsg: "For exceptional dining, I would recommend: Zuma Miami for refined Japanese cuisine, Joe's Stone Crab for an iconic Miami seafood experience, or Stubborn Seed — a Michelin-recognised establishment offering exceptional contemporary fare.", category: "Local Recommendations", time: "7:15 PM" },
    { guest: "Sofia", guestMsg: "can I get mid-stay cleaning?", leahMsg: "I shall coordinate with the host regarding mid-stay housekeeping arrangements and communicate their response to you directly. You will hear from me shortly. The service is $85 with 24 hours notice.", category: "Upsell Service", time: "10:05 AM" },
    { guest: "David", guestMsg: "¿hablas español?", leahMsg: "Con mucho gusto. Soy LEAH, su concierge personal. Hablo español con fluidez. ¿En qué puedo asistirle el día de hoy? Puedo ayudarle con WiFi, reglas de la casa, estacionamiento y recomendaciones.", category: "Multi-Language", time: "8:30 PM" },
    { guest: "Isabella", guestMsg: "what are the quiet hours?", leahMsg: "The residence observes quiet hours between 10:00 PM and 8:00 AM. This ensures all guests enjoy a peaceful stay. Private driveway parking is available exclusively for your use.", category: "House Rules", time: "9:15 PM" }
];

let currentReelIndex = 0;
let reelInterval;

function createReelHTML(reel, index) {
    return `
        <div class="chat-reel ${index === 0 ? 'active' : ''}" data-index="${index}">
            <div class="reel-messages">
                <div class="reel-message guest">
                    <div class="reel-bubble guest">
                        <div class="reel-name guest">${reel.guest}</div>
                        ${reel.guestMsg}
                        <div class="reel-time">${reel.time}</div>
                    </div>
                </div>
                <div class="reel-message leah">
                    <div class="reel-bubble leah">
                        <div class="reel-name leah">LEAH · Concierge</div>
                        ${reel.leahMsg}
                        <div class="reel-time">${reel.time}</div>
                    </div>
                </div>
                <div class="reel-category">✦ ${reel.category} ✦</div>
            </div>
        </div>
    `;
}

function buildReels() {
    const carousel = document.getElementById('chatReelsCarousel');
    const indicators = document.getElementById('reelIndicators');
    if (!carousel) return;
    
    carousel.innerHTML = '';
    indicators.innerHTML = '';
    
    chatReels.forEach((reel, i) => {
        carousel.insertAdjacentHTML('beforeend', createReelHTML(reel, i));
        const dot = document.createElement('div');
        dot.className = `reel-dot ${i === 0 ? 'active' : ''}`;
        dot.addEventListener('click', () => goToReel(i));
        indicators.appendChild(dot);
    });
}

function goToReel(index) {
    const reels = document.querySelectorAll('.chat-reel');
    const dots = document.querySelectorAll('.reel-dot');
    if (!reels.length) return;
    
    reels[currentReelIndex].classList.remove('active');
    dots[currentReelIndex].classList.remove('active');
    
    currentReelIndex = index;
    
    reels[currentReelIndex].classList.add('active');
    dots[currentReelIndex].classList.add('active');
    
    // Reset interval
    if (reelInterval) clearInterval(reelInterval);
    reelInterval = setInterval(nextReel, 7000);
}

function nextReel() {
    const next = (currentReelIndex + 1) % chatReels.length;
    goToReel(next);
}

// Initialize reels and start auto-rotation
setTimeout(() => {
    buildReels();
    reelInterval = setInterval(nextReel, 7000);
}, 500);

// ============================================================================
// LANGUAGE TOGGLE (SPANISH/ENGLISH)
// ============================================================================
let currentLang = 'en';

function updateLanguage(lang) {
    const elements = document.querySelectorAll('[data-en][data-es]');
    elements.forEach(el => {
        if (lang === 'es' && el.dataset.es) {
            el.textContent = el.dataset.es;
        } else if (lang === 'en' && el.dataset.en) {
            el.textContent = el.dataset.en;
        }
    });
    currentLang = lang;
}

document.getElementById('langToggle')?.addEventListener('click', () => {
    const newLang = currentLang === 'en' ? 'es' : 'en';
    updateLanguage(newLang);
});

// ============================================================================
// CURSOR
// ============================================================================
const cursor = document.getElementById('cursor');
const cf = document.getElementById('cursorFollower');
let mx = 0, my = 0, fx = 0, fy = 0;
document.addEventListener('mousemove', e => {
    mx = e.clientX; my = e.clientY;
    if (cursor) cursor.style.transform = `translate(${mx-2.5}px,${my-2.5}px)`;
});
function tick() {
    fx += (mx - fx) * 0.12; fy += (my - fy) * 0.12;
    if (cf) cf.style.transform = `translate(${fx-19}px,${fy-19}px)`;
    requestAnimationFrame(tick);
}
tick();
document.querySelectorAll('a,button,.philosophy-card,.capability-card,.workflow-step').forEach(el => {
    el.addEventListener('mouseenter', () => { cursor?.classList.add('expanded'); cf?.classList.add('expanded'); });
    el.addEventListener('mouseleave', () => { cursor?.classList.remove('expanded'); cf?.classList.remove('expanded'); });
});

// ============================================================================
// NAV
// ============================================================================
const nav = document.getElementById('mainNav');
window.addEventListener('scroll', () => nav?.classList.toggle('scrolled', scrollY > 60));
const hamburger = document.getElementById('hamburger');
const navLinks = document.getElementById('navLinks');
hamburger?.addEventListener('click', () => navLinks?.classList.toggle('open'));
navLinks?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => navLinks.classList.remove('open')));

// ============================================================================
// SCROLL REVEAL
// ============================================================================
const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
document.querySelectorAll('.reveal,.reveal-right').forEach(el => observer.observe(el));

// ============================================================================
// CHAT INTERFACE
// ============================================================================
const chatBody = document.getElementById('chatBody');
const chatInput = document.getElementById('chatInput');
const chatSend = document.getElementById('chatSend');

const leahResponses = {
    'wifi': "The WiFi network is VillaLumina_Guest and the password is MiamiSun2024. The router is in the living room cabinet. May I assist you further?",
    'password': "The WiFi passphrase is MiamiSun2024. Is there anything else I can do for you?",
    'check-in': "Check-in is at 4:00 PM. Your access code is 7742#. The property will be fully prepared for your arrival.",
    'checkout': "Departure is scheduled for 11:00 AM. It has been a privilege hosting you.",
    'house rules': "Quiet hours: 10:00 PM to 8:00 AM. No gatherings beyond registered guests. Private parking is available.",
    'pool': "The pool is ready. I can arrange heating with 24 hours notice. Shall I coordinate that for you?",
    'restaurant': "Zuma Miami (Japanese), Joe's Stone Crab (seafood), or Stubborn Seed (contemporary). Would you like addresses or reservations?",
    'toilet': "I apologise. I am notifying the property manager immediately. Expect contact within 30 minutes.",
    'cleaning': "I will coordinate with the host regarding mid-stay cleaning. You will hear from me shortly.",
    'hello': "Good day. I am LEAH, your dedicated concierge. How may I elevate your stay?",
    'hola': "Con mucho gusto. Soy LEAH, su concierge. ¿En qué puedo asistirle?",
    'bonjour': "Bonjour. Je suis LEAH, votre concierge. Comment puis-je vous aider?",
    'parking': "Private driveway parking is reserved for you. Accommodation for up to two vehicles.",
    'help': "I am at your service. I can assist with WiFi, access, house protocols, dining recommendations, local attractions, maintenance concerns, and any matter pertaining to your comfort."
};

function getTime() { return new Date().toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }); }
function getLeahReply(msg) {
    const l = msg.toLowerCase();
    for (const [k, v] of Object.entries(leahResponses)) { if (l.includes(k)) return v; }
    return "I wish to be of service. Could you elaborate? I am equipped to assist with property access, dining, local guidance, and any matter pertaining to your comfort.";
}

function appendMsg(text, isGuest) {
    const row = document.createElement('div');
    row.className = `chat-msg-row${isGuest ? ' guest' : ''}`;
    if (isGuest) {
        row.innerHTML = `<div class="avatar-guest chat-avatar">G</div><div><div class="bubble-guest chat-bubble">${text}<div class="bubble-time">${getTime()}</div></div></div>`;
    } else {
        row.innerHTML = `<div class="avatar-leah chat-avatar">L</div><div><div class="bubble-leah chat-bubble"><div class="bubble-leah-name">LEAH · Concierge</div>${text}<div class="bubble-time">${getTime()}</div></div></div>`;
    }
    chatBody.appendChild(row);
    chatBody.scrollTop = chatBody.scrollHeight;
}

function showTyping() {
    const el = document.createElement('div');
    el.className = 'chat-typing'; el.id = 'typingIndicator';
    el.innerHTML = `<div class="avatar-leah chat-avatar" style="width:32px;height:32px;">L</div><div class="typing-dots"><div class="typing-dot"></div><div class="typing-dot"></div><div class="typing-dot"></div></div>`;
    chatBody.appendChild(el);
    chatBody.scrollTop = chatBody.scrollHeight;
}
function hideTyping() { const el = document.getElementById('typingIndicator'); if (el) el.remove(); }

function sendMessage() {
    const msg = chatInput.value.trim();
    if (!msg) return;
    appendMsg(msg, true);
    chatInput.value = '';
    showTyping();
    setTimeout(() => { hideTyping(); appendMsg(getLeahReply(msg), false); }, 800);
}

chatSend?.addEventListener('click', sendMessage);
chatInput?.addEventListener('keypress', e => { if (e.key === 'Enter') sendMessage(); });

// ============================================================================
// COOKIE CONSENT
// ============================================================================
const cookieBanner = document.getElementById('cookieConsent');
if (!localStorage.getItem('cookieConsent')) setTimeout(() => cookieBanner?.classList.add('show'), 1200);
document.getElementById('acceptCookies')?.addEventListener('click', () => { localStorage.setItem('cookieConsent','accepted'); cookieBanner?.classList.remove('show'); });
document.getElementById('declineCookies')?.addEventListener('click', () => { localStorage.setItem('cookieConsent','declined'); cookieBanner?.classList.remove('show'); });

