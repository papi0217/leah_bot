    copyright: { title: 'Copyright Notice', body: `<h3>Copyright Notice</h3><p><strong>© 2025 SOLUTIONa4U</strong></p><p>All content on this platform, including copy, graphics, logotypes, software, and the LEAH Bot system, constitutes the exclusive intellectual property of SOLUTIONa4U and is protected under United States and international copyright legislation.</p>` }
};
const overlayLegal = document.getElementById('legalOverlay');
const legalTitle = document.getElementById('legalTitle');
const legalBody = document.getElementById('legalBody');
document.querySelectorAll('[data-legal]').forEach(link => {
    link.addEventListener('click', e => {
        e.preventDefault();
        const k = link.dataset.legal;
        if (legalContent[k]) { legalTitle.textContent = legalContent[k].title; legalBody.innerHTML = legalContent[k].body; overlayLegal.classList.add('active'); }
