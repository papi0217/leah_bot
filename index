.email-card {
    display: flex; align-items: center; gap: 1.6rem;
    background: linear-gradient(145deg, #FFFFFF, #F8F3EA);
    border: 1px solid rgba(184,134,11,0.2);
    padding: 2rem 3rem;
    text-decoration: none;
    transition: all 0.4s;
}
.email-icon-wrap {
    width: 50px; height: 50px; border-radius: 50%;
    background: var(--gold-metal);
    display: flex; align-items: center; justify-content: center;
    color: var(--obsidian);
}
.email-lbl { font-size: 0.58rem; letter-spacing: 2.5px; text-transform: uppercase; color: var(--ink-faint); display: block; }
.email-val { font-family: 'Cormorant Garamond', serif; font-size: 1.5rem; color: var(--ink-mid); }
