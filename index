.disclaimer-container { max-width: 1200px; margin: 0 auto; font-size: 0.67rem; color: rgba(138,138,154,0.55); text-align: center; }
.footer {
    padding: 4rem 5% 2rem;
    background: #040406;
}
.footer-content { max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.4fr repeat(4,1fr); gap: 2.5rem; }
.footer-links h4 { font-size: 0.6rem; letter-spacing: 2px; text-transform: uppercase; margin-bottom: 1.2rem; color: var(--pearl-dim); }
.footer-links a { display: block; color: var(--steel); text-decoration: none; font-size: 0.78rem; margin-bottom: 0.6rem; transition: color 0.3s; }
.footer-links a:hover { color: var(--gold-2); }
.footer-bottom { text-align: center; padding-top: 2.5rem; margin-top: 3rem; border-top: 1px solid rgba(255,255,255,0.04); font-size: 0.67rem; color: rgba(138,138,154,0.4); }
.cookie-consent {
    position: fixed; bottom: 0; left: 0; right: 0;
    background: rgba(8,8,10,0.97);
    border-top: 1px solid rgba(184,134,11,0.15);
    backdrop-filter: blur(24px);
    color: var(--pearl); padding: 1.2rem 5%;
    z-index: 10000; display: flex;
    justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 1rem;
