}
.reveal { opacity: 0; transform: translateY(36px); transition: opacity 0.85s cubic-bezier(0.16,1,0.3,1), transform 0.85s cubic-bezier(0.16,1,0.3,1); }
.reveal.visible { opacity: 1; transform: translateY(0); }
.reveal-right { opacity: 0; transform: translateX(48px); transition: opacity 0.9s cubic-bezier(0.16,1,0.3,1), transform 0.9s cubic-bezier(0.16,1,0.3,1); }
.reveal-right.visible { opacity: 1; transform: translateX(0); }

h1, h2, h3 { font-family: 'Cormorant Garamond', serif; font-weight: 500; }
h1 { font-size: clamp(3.4rem, 7.2vw, 6.8rem); line-height: 1.02; font-weight: 600; letter-spacing: -0.03em; }
h2 { font-size: clamp(2.2rem, 4.5vw, 3.8rem); line-height: 1.14; font-weight: 500; letter-spacing: -0.02em; }
.gold-text { background: var(--gold-metal); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
.section-label { font-family: 'Jost', sans-serif; font-size: 0.62rem; letter-spacing: 4.5px; text-transform: uppercase; color: var(--gold-3); font-weight: 500; }
